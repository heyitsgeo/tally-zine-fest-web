---
import About from '@/components/about.astro';
import Contact from '@/components/contact.astro';
import Hero from '@/components/hero.astro';
import Layout from '../layouts/Layout.astro';
import Speakers from '@/components/speakers.astro';
import Faqs from '@/components/faqs.astro';
import Vendors from '@/components/vendors.astro';
import Workshops from '@/components/workshops.astro';
import { actions } from 'astro:actions';
import { randomUUID } from 'crypto';

const result = Astro.getActionResult(actions.submitContactForm);

if (result && !result.error) {
	return Astro.redirect('/contact/success');
}
---

<Layout>
	<Hero />
	<About />
	<!-- <Speakers /> -->
	<!-- <Workshops /> -->
	<Vendors />
	<!-- <Faqs /> -->
	<Contact />
</Layout>
