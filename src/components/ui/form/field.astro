---
import type { HTMLAttributes } from 'astro/types';

/**
 * Field Component
 *
 * @description Field container for input, label, and error messages
 */

type Props = {} & HTMLAttributes<'div'>;

const { class: className, ...rest } = Astro.props;
---

<div class:list={['flex flex-col gap-1.5', className]} {...rest}>
	<slot />
</div>
