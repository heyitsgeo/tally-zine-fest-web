---
import Link from '@/components/ui/link.astro';
import type { ComponentProps } from 'astro/types';

/**
 * NavLink Component
 */
type Props = {} & ComponentProps<typeof Link>;
const { class: className, ...rest } = Astro.props;
---

<Link
	class:list={[
		'text-accent-800 hover:text-primary-200 flex items-center justify-center p-2 transition-colors hover:scale-110',
		className,
	]}
	{...rest}
>
	<slot />
</Link>
