<style>
	:where(.footer-letter) {
		visibility: hidden;
	}
</style>

<noscript>
	<style>
		:where(.footer-letter) {
			visibility: visible;
		}
	</style>
</noscript>

<script>
	import gsap from 'gsap';
	import { ScrollTrigger } from 'gsap/ScrollTrigger';

	gsap.registerPlugin(ScrollTrigger);

	const letters = document.querySelectorAll('.footer-letter');

	const mediaMatcher = gsap.matchMedia();

	mediaMatcher.add(
		{
			reduceMotion: '(prefers-reduced-motion: reduce)',
			fullMotion: '(prefers-reduced-motion: no-preference)',
		},
		(matcherContext) => {
			const { reduceMotion } = matcherContext.conditions ?? {};

			gsap.from(letters, {
				autoAlpha: 0,
				duration: reduceMotion ? 0 : 0.5,
				opacity: 0,
				y: reduceMotion ? 0 : 50,
				ease: 'power1.in',
				stagger: {
					each: reduceMotion ? 0 : 0.1,
				},
				scrollTrigger: {
					trigger: '.footer-logo',
					start: 'top 95%',
					once: true,
				},
			});
		},
	);
</script>
