---
const workshops = [
	{
		time: '10:00 AM',
		title: 'Risograph Printing Basics',
		host: 'Host TBA',
		description:
			'Hands-on introduction to riso printing — how it works, what makes it unique, and how to start making prints yourself.',
		capacity: '20 seats',
	},
	{
		time: '1:00 PM',
		title: 'Bookbinding 101',
		host: 'Host TBA',
		description:
			'Fold, cut, and bind your own mini zine from scratch. All materials provided — leave with something handmade.',
		capacity: '15 seats',
	},
	{
		time: '3:00 PM',
		title: 'Zine Trading & Networking',
		host: 'Open to All',
		description:
			'An informal structured trade session for creators to swap work, make connections, and grow their collections.',
		capacity: 'Open',
	},
];
---

<section aria-labelledby="workshops-heading">
<div class="content-container">
		<div class="flex flex-col gap-10">
			<div class="flex flex-col gap-2">
				<span class="font-monotalic text-accent-800 text-[0.65rem] tracking-[0.25em] uppercase">Schedule</span>
				<h2
					id="workshops-heading"
					class="font-monotalic text-secondary-500 after:bg-primary-200 relative w-fit text-3xl after:absolute after:right-0 after:bottom-0 after:left-0 after:-z-10 after:h-4"
				>Workshops</h2>
			</div>

			<ul class="m-0 list-none divide-y-2 divide-accent-800/15 p-0">
				{
					workshops.map((workshop) => (
						<li class="grid gap-4 py-7 first:pt-0 last:pb-0 sm:grid-cols-[6rem_1fr_auto] sm:gap-8">
							<div class="font-monotalic text-sm text-secondary-500">{workshop.time}</div>
							<div class="flex flex-col gap-1.5">
								<h3 class="font-monotalic text-xl text-accent-800">{workshop.title}</h3>
								<p class="font-monotalic text-[0.65rem] uppercase tracking-[0.15em] text-accent-800/50">
									{workshop.host}
								</p>
								<p class="mt-1.5 text-sm font-normal leading-relaxed">{workshop.description}</p>
							</div>
							<div class="font-monotalic self-start whitespace-nowrap border border-secondary-500 px-2.5 py-1.5 text-[0.6rem] uppercase tracking-[0.15em] text-secondary-500 sm:self-center">
								{workshop.capacity}
							</div>
						</li>
					))
				}
			</ul>
		</div>
	</div>
</section>
